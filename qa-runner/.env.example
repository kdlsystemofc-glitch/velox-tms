# Velox QA runner — copie este arquivo para `.env` e preencha.
# NUNCA versione o .env (já está no .gitignore).

# Chave da API da Anthropic (obrigatória) — o agente Claude roda com ela.
ANTHROPIC_API_KEY=

# Alvo da simulação (padrão = produção). Pode apontar para um preview/staging.
VELOX_URL=https://velox-tms.vercel.app

# Credenciais (obrigatório ao menos admin). Operador e motorista são opcionais
# mas necessários para testar permissões e o portal do motorista.
ADMIN_EMAIL=
ADMIN_PASSWORD=
OPERATOR_EMAIL=
OPERATOR_PASSWORD=
DRIVER_EMAIL=
DRIVER_PASSWORD=

# Opcional — para testar "Otimizar rota" com distância real do Google Maps.
GOOGLE_MAPS_API_KEY=

# Ajustes do runner (opcionais)
# QA_MODEL=claude-opus-4-8
# MAX_TURNS=1500
