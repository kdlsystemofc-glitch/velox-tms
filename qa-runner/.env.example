# Velox QA runner — copie este arquivo para `.env` e preencha.
# NUNCA versione o .env (já está no .gitignore).

# Autenticação (escolha UM modo):
#  A) Pagar por uso (API): preencha ANTHROPIC_API_KEY abaixo.
#  B) Usar a ASSINATURA Pro/Max: DEIXE EM BRANCO e, antes de rodar, faça
#     `claude` -> `/login` com a conta da assinatura (sem cobrança por token).
ANTHROPIC_API_KEY=

# Alvo da simulação (padrão = produção). Pode apontar para um preview/staging.
VELOX_URL=https://velox-tms.vercel.app

# ADMIN: login JÁ EXISTENTE (obrigatório). É por ele que o agente entra.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# OPERADOR e MOTORISTA: o AGENTE CRIA esses logins durante a simulação
# (Usuários → Novo usuário; e Frota → Motorista → Acesso ao app). Aqui você
# só DEFINE as credenciais que ele deve usar ao criar — assim você fica sabendo
# quais são. Se deixar em branco, o agente inventa e informa no relatório.
OPERATOR_EMAIL=operador.qa@velox.teste
OPERATOR_PASSWORD=
DRIVER_EMAIL=motorista.qa@velox.teste
DRIVER_PASSWORD=

# Opcional — para testar "Otimizar rota" com distância real do Google Maps.
GOOGLE_MAPS_API_KEY=

# Ajustes do runner (opcionais)
# QA_MODEL=claude-opus-4-8
# MAX_TURNS=1500
